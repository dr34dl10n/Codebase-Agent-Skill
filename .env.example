# Database
CODEINDEX_DB_HOST=localhost
CODEINDEX_DB_PORT=5432
CODEINDEX_DB_NAME=codeindex
CODEINDEX_DB_USER=codeindex
CODEINDEX_DB_PASSWORD=CHANGE_ME

# Embeddings
#
# Default: modernbert-embed-base (sentence-transformers backend)
# Auto-downloads from HuggingFace — no Ollama or external service needed.
#
# Run `python scripts/detect_model.py --write-env` to auto-detect the best model
# for your hardware. It will write CODEINDEX_EMBED_MODEL to this file.
#
# Available models:
#   modernbert-embed-base   – 768-dim, 8192 ctx – DEFAULT, CPU-friendly, zero config
#   modernbert-embed-large  – 1024-dim, 8192 ctx – better quality, more RAM
#   nomic-embed-text         – 768-dim, ~8k ctx – requires Ollama (GPU ≥8 GB)
#
# Backend is auto-detected from model name:
#   modernbert-* → sentence_transformers
#   nomic-*      → ollama
#
#CODEINDEX_EMBED_MODEL=modernbert-embed-base
#CODEINDEX_EMBED_BACKEND=sentence_transformers
CODEINDEX_EMBED_API_BASE=http://localhost:11434

# API server (optional — for FastAPI endpoints)
CODEINDEX_API_HOST=127.0.0.1
CODEINDEX_API_PORT=8900